# ============================================
# Cạp Nông - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ─── PostgreSQL (Production: use RDS endpoint) ─
POSTGRES_DB=capnong_dev
POSTGRES_USER=capnong
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5432

# Production only: RDS endpoint from terraform output
# RDS_ENDPOINT=your-rds-endpoint.rds.amazonaws.com

# ─── Redis ─────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ─── JWT ───────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_min_256_bits
JWT_EXPIRATION_MS=86400000

# ─── Google Gemini AI ──────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── Telegram Bot ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# ─── Cloudinary ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ─── Backend ───────────────────────────────────
BACKEND_PORT=8080
AI_SERVICE_URL=http://localhost:8001

# ─── Frontend ──────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=Cạp Nông

# ─── Kafka ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Domain (Production only) ──────────────────
# DOMAIN_NAME=capnong.vn
