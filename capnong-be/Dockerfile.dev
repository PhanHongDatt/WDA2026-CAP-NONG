# ============================================
# Cạp Nông - Backend Development Dockerfile
# Java 21 + Spring Boot 3 with Hot Reload
# ============================================

FROM eclipse-temurin:21-jdk

WORKDIR /app

# Install Maven
RUN sed -i 's/archive.ubuntu.com/mirror.kku.ac.th/g' /etc/apt/sources.list.d/ubuntu.sources || true && \
    sed -i 's/security.ubuntu.com/mirror.kku.ac.th/g' /etc/apt/sources.list.d/ubuntu.sources || true && \
    apt-get update && \
    apt-get install -y maven && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Copy pom.xml first for dependency caching
COPY pom.xml ./

# Download dependencies (cached layer)
RUN mvn dependency:go-offline -B 2>/dev/null || true

# Copy source code
COPY src/ src/

# Expose application port + remote debug port
EXPOSE 8080 5005

# Run Spring Boot with hot reload and remote debugging enabled
CMD ["mvn", "spring-boot:run", "-Dmaven.test.skip=true", \
     "-Dspring-boot.run.jvmArguments=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005"]

